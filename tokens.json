{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": {
    "name": "Mentis Digital",
    "tagline": "Managed BD for Recruitment Agencies"
  },
  "color": {
    "primary-dark": { "value": "#1A3A5C", "name": "Deep Space Blue" },
    "primary-bright": { "value": "#2878E8", "name": "Crayola Blue" },
    "accent-warm": { "value": "#D4980F", "name": "Harvest Gold" },
    "background-light": { "value": "#F2F6FB", "name": "Alice Blue" },
    "mid-tone": { "value": "#8AABC8", "name": "Sky Reflection" },
    "text-dark": { "value": "#0F2237", "name": "Ink" }
  },
  "font": {
    "headline": { "family": "Fraunces", "source": "Google Fonts", "weights": [400, 500, 600, 700] },
    "body": { "family": "Inter", "source": "Google Fonts", "weights": [400, 500, 600, 700] }
  },
  "typescale": {
    "h1": { "size": "3.25rem", "weight": 700, "family": "Fraunces", "lineHeight": 1.1, "letterSpacing": "-0.02em" },
    "h2": { "size": "2.375rem", "weight": 600, "family": "Fraunces", "lineHeight": 1.15, "letterSpacing": "-0.015em" },
    "h3": { "size": "1.625rem", "weight": 600, "family": "Fraunces", "lineHeight": 1.2, "letterSpacing": "-0.01em" },
    "body": { "size": "1.0625rem", "weight": 400, "family": "Inter", "lineHeight": 1.6 },
    "small": { "size": "0.875rem", "weight": 400, "family": "Inter", "lineHeight": 1.5 },
    "overline": { "size": "0.78rem", "weight": 500, "family": "Inter", "lineHeight": 1.4, "letterSpacing": "0.08em", "textTransform": "uppercase" }
  },
  "rules": {
    "gold-max-percent": 5,
    "body-text-opacity": 0.85,
    "never-use-pure-black": "#000000 forbidden — use #0F2237",
    "never-use-pure-white-bg": "#FFFFFF forbidden for backgrounds — use #F2F6FB"
  }
}
